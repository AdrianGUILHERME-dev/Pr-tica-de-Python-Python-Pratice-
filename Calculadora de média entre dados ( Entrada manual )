n=0
soma=0.0
valor = '1'
valores = []
vazio = []

print("CALCULADORA DE MÉDIA\n\n")
print("Instruções: \n'0' para encerrar e exibir o resultado.\n'del' para apagar dado na posição especificada. \n'all' para apagar todos os elementos.\n'media' mostra a media entre os termos listados.\n")

while valor != '0':

#Mostra a lista de dados atual e recebe o próximo valor a ser adicionado.

    print("Lista atual", valores)
    valor = input("Digite um número ou comando:")
    print("\n")

#Verifica qual opção foi selecionada e responde de acordo
    #(Del)- Se a lista estiver vazia = mensagem de erro, se não, deleta o termo na posição especificada ou tudo caso seja selecionado o 'all'.

    if valor == 'del':

        if valores == vazio:
            print("A lista está vazia")
            continue

        else :
            try:
                posicao=input("Qual elemento?") #Trata-se de uma string, para realizar operações matemáticas, adicione int() ou float()
            except (ValueError, SyntaxError):
                print("Digite valores válidos, somente inteiros")

            if posicao != 'all' :

                if int(posicao) > n or int(posicao) < 0 :
                    print("ERRO: Posição inválida ou inexistente")

                else:
                    soma = soma - valores[int(posicao) - 1]
                    n = n - 1
                    valor = 0
                    print("Número", valores[int(posicao) - 1]," apagado.")
                    del valores[int(posicao) - 1]

            elif posicao == 'all':
                print("Valores excluidos:", valores)
                valores = vazio


    #(0) - Comando de encerramento de loop. Para a execução e se houverem dados na lista, mostra a media na tela.

    elif valor == '0':
        print("Programa encerrado")
        break

    #(Qualquer número) - Acrescenta o valor especificado a lista e incrementa a contagem de elementos em 1.

    elif valor == 'media':

        if n > 0:
            media = soma/n
            print("A média entre ", valores,"é igual a ", media,"\n")
            continue
        else:
            print("Não há valores listados.\n")
            continue


    else:
        try:
            soma = soma + float(valor)
            n = n + 1
            valores.append(float(valor))

        except (ValueError, SyntaxError):
            print("Digite apenas números!\n")
            continue






